# Docker Compose ports
FRONTEND_PORT=4173
BACKEND_PORT=8000
POSTGRES_PORT=5432

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_shopping_copilot

# Backend AI configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro
HUGGINGFACE_API_KEY=

# Browser-facing API URL baked into the Vite frontend image
VITE_API_BASE_URL=http://localhost:8000/api
